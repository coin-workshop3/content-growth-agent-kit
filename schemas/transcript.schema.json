{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/coin-workshop3/content-growth-agent-kit/schemas/transcript.schema.json",
  "title": "Local talking-head transcript and review state",
  "type": "object",
  "required": ["reviewed", "segments"],
  "properties": {
    "schema_version": {"type": "string"},
    "reviewed": {"type": "boolean"},
    "source_asset_id": {"type": "string"},
    "source": {"type": "string"},
    "language": {"type": "string"},
    "provider": {"type": "string"},
    "model": {"type": "string"},
    "source_upload": {"const": false},
    "review_gate": {"enum": ["needs_human_review", "reviewed"]},
    "filler_review": {
      "type": "object",
      "required": ["candidates", "candidate_count", "automatic_deletion", "gate"],
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["candidate_id", "segment_id", "kind", "phrase", "confidence", "estimated_start", "estimated_end", "timestamp_precision", "suggested_action"],
            "properties": {
              "candidate_id": {"type": "string"},
              "segment_id": {"type": ["string", "null"]},
              "kind": {"enum": ["hesitation", "repetition"]},
              "phrase": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "estimated_start": {"type": "number", "minimum": 0},
              "estimated_end": {"type": "number", "minimum": 0},
              "timestamp_precision": {"const": "estimated_from_segment"},
              "suggested_action": {"const": "human_review"}
            },
            "additionalProperties": true
          }
        },
        "candidate_count": {"type": "integer", "minimum": 0},
        "automatic_deletion": {"const": false},
        "gate": {"const": "human_decision_required"},
        "limitations": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["start", "end", "text"],
        "properties": {
          "id": {"type": "string"},
          "start": {"type": "number", "minimum": 0},
          "end": {"type": "number", "exclusiveMinimum": 0},
          "text": {"type": "string"},
          "keep": {"type": "boolean"},
          "action": {"enum": ["keep", "delete", "review"]},
          "role": {"enum": ["Hook", "Problem", "SceneEmotion", "Product", "Proof", "CTA"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

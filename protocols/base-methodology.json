{
  "schema_version": "0.4",
  "protocol_id": "content-growth-base-v0.4",
  "license_scope": "Apache-2.0 open base methodology",
  "geo": {
    "positioning": "AI answer discovery + platform search + AI parsing + monitoring",
    "layers": [
      "ai-answer-discovery",
      "platform-search",
      "ai-parsing",
      "monitoring-and-retro"
    ],
    "task_types": [
      "customer-language",
      "comparison",
      "proof",
      "scenario",
      "delivery-boundary"
    ],
    "monitoring_metrics": [
      "presence",
      "recommendation_rank",
      "citation_quality",
      "accuracy",
      "competitor_share"
    ],
    "gate": {
      "requires_core_offer": true,
      "missing_evidence_status": "needs_evidence",
      "observed_answers_must_not_be_invented": true
    }
  },
  "score": {
    "pass_threshold": 6.0,
    "blocked_reasons_override_score": true,
    "dimensions": [
      {
        "key": "ER",
        "label": "Pain resonance",
        "weight": 1.5,
        "low_score_action": "加入一条具体客户原话、触发场景或可感知成本。"
      },
      {
        "key": "SR",
        "label": "Search resonance",
        "weight": 1.5,
        "low_score_action": "明确一个真实搜索问题、意图和核心实体。"
      },
      {
        "key": "HP",
        "label": "Hook strength",
        "weight": 1.5,
        "low_score_action": "把开头改为具体风险、反差、判断或即时收益。"
      },
      {
        "key": "QL",
        "label": "Quotable judgment",
        "weight": 1.0,
        "low_score_action": "增加一句有边界且有证据支撑的判断句。"
      },
      {
        "key": "NA",
        "label": "Decision path",
        "weight": 1.0,
        "low_score_action": "补齐问题、标准、证据、边界和下一步的决策链。"
      },
      {
        "key": "AB",
        "label": "Valuable audience",
        "weight": 1.0,
        "low_score_action": "缩小到明确的买方、决策人或高价值使用者。"
      },
      {
        "key": "SAT",
        "label": "Differentiation sharpness",
        "weight": 1.0,
        "low_score_action": "加入可验证的对比、避坑标准或取舍。"
      }
    ]
  },
  "video": {
    "modes": {
      "talking_head_cleanup": {
        "label": "口播精剪",
        "aliases": ["talking-head"],
        "best_for": ["single talking-head video", "owner or creator explanation", "trust-led B2B content"],
        "base_path": {
          "dependencies": ["ffmpeg", "ffprobe"],
          "method": "silencedetect with conservative padding",
          "formal_gate": "preview_only",
          "limitation": "Silence boundaries do not prove sentence or semantic safety."
        },
        "reviewed_path": {
          "dependencies": ["ffmpeg", "ffprobe", "reviewed timestamped transcript"],
          "method": "transcript-driven keep/delete spans with join review",
          "formal_gate": "ready_for_human_review"
        },
        "automatic_transcript_path": {
          "dependencies": ["ffmpeg", "ffprobe", "local OpenAI Whisper CLI"],
          "method": "local timestamped transcription with no source upload",
          "formal_gate": "preview_only_until_transcript_reviewed",
          "model_download_may_be_required": true
        },
        "standards": {
          "aspect": "9:16",
          "fps": 30,
          "sentence_safe_cuts_require_reviewed_transcript": true,
          "subtitle_style": "white text, black stroke, yellow keyword emphasis",
          "subtitle_layout": "single-line timed phrases",
          "end_fade_sec": 1.0,
          "never_claim_semantic_cleanup_without_reviewed_transcript": true
        }
      },
      "scripted_asset_assembly": {
        "label": "素材拼接",
        "aliases": ["material-assembly"],
        "best_for": ["structured script plus multiple local assets", "FAQ or proof videos", "product and delivery scenes"],
        "base_path": {
          "dependencies": ["ffmpeg", "ffprobe"],
          "method": "script segment and filename/folder tag matching",
          "formal_gate": "draft_requires_human_review"
        },
        "standards": {
          "semantic_roles": ["Hook", "Problem", "SceneEmotion", "Product", "Proof", "CTA"],
          "missing_asset_blocks_render": true,
          "prefer_unused_assets": true,
          "same_product_series_required_for_effect_review": true,
          "confirmed_spoken_copy_required_for_formal_caption_acceptance": true
        }
      }
    },
    "capability_levels": {
      "basic": {
        "dependencies": [
          "ffmpeg",
          "ffprobe"
        ],
        "outputs": [
          "asset index",
          "tag-matched EDL",
          "basic 9:16 MP4 draft",
          "timed SRT sidecar captions"
        ]
      },
      "local_transcription_optional": {
        "dependencies": [
          "OpenAI Whisper CLI",
          "local model files"
        ],
        "outputs": [
          "unreviewed timestamped transcript",
          "transcript-driven preview cut candidates"
        ],
        "source_upload": false,
        "human_transcript_review_required": true
      },
      "advanced_optional": {
        "dependencies": [
          "WhisperX",
          "auto-editor",
          "pysubs2",
          "Remotion or HyperFrames",
          "pyJianYingDraft"
        ],
        "outputs": [
          "word timestamps",
          "reviewed transcript cut candidates",
          "styled captions",
          "motion packaging",
          "Jianying draft export"
        ]
      }
    },
    "render": {
      "width": 1080,
      "height": 1920,
      "fps": 30,
      "video_codec": "libx264",
      "audio_codec": "aac",
      "talking_head_end_fade_sec": 1.0,
      "caption_fallback": "sidecar_srt",
      "caption_burn_in_requires": "ffmpeg subtitles/libass filter"
    },
    "gates": {
      "missing_asset_blocks_render": true,
      "human_review_required": true,
      "never_upload_or_publish_automatically": true,
      "never_modify_source_media": true
    }
  }
}

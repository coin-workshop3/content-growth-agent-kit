{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/coin-workshop3/content-growth-agent-kit/schemas/video-script.schema.json",
  "title": "Local video script",
  "type": "object",
  "required": ["script_id", "segments"],
  "properties": {
    "schema_version": {"type": "string"},
    "script_id": {"type": "string", "minLength": 1},
    "aspect_ratio": {"enum": ["9:16"]},
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "text", "duration", "asset_tags"],
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string"},
          "text": {"type": "string"},
          "duration": {"type": "number", "exclusiveMinimum": 0},
          "asset_tags": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

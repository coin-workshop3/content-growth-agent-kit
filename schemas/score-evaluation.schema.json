{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/coin-workshop3/content-growth-agent-kit/schemas/score-evaluation.schema.json",
  "title": "Agent-authored enterprise content evaluation",
  "type": "object",
  "required": ["content_id", "track", "dimensions", "blocked_reasons"],
  "properties": {
    "content_id": {"type": "string"},
    "track": {"type": "string"},
    "dimensions": {
      "type": "object",
      "required": ["ER", "SR", "HP", "QL", "NA", "AB", "SAT"],
      "additionalProperties": false,
      "properties": {
        "ER": {"$ref": "#/$defs/dimension"},
        "SR": {"$ref": "#/$defs/dimension"},
        "HP": {"$ref": "#/$defs/dimension"},
        "QL": {"$ref": "#/$defs/dimension"},
        "NA": {"$ref": "#/$defs/dimension"},
        "AB": {"$ref": "#/$defs/dimension"},
        "SAT": {"$ref": "#/$defs/dimension"}
      }
    },
    "blocked_reasons": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "required": ["score", "reason", "evidence"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 5},
        "reason": {"type": "string", "minLength": 1},
        "evidence": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  }
}
